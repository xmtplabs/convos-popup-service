<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Join Group - Convos</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body {
      font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
      max-width: 480px;
      margin: 0 auto;
      padding: 48px 20px;
      color: #000;
      background: #fff;
      -webkit-font-smoothing: antialiased;
    }
    .card {
      border: 1px solid #ebebeb;
      border-radius: 24px;
      padding: 40px 32px;
      text-align: center;
    }
    .logo { margin-bottom: 24px; }
    h1 { font-size: 32px; font-weight: 700; letter-spacing: -0.5px; }
    .subtitle { color: #666; font-size: 15px; margin: 8px 0 24px; }
    .app-icon { width: 64px; height: 64px; border-radius: 16px; object-fit: contain; }
    .info {
      background: #f5f5f5;
      border-radius: 16px;
      padding: 20px;
      margin: 20px 0 0;
      text-align: left;
    }
    .info dt {
      font-size: 13px;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 0.5px;
      color: #b2b2b2;
      margin-top: 12px;
    }
    .info dt:first-child { margin-top: 0; }
    .info dd { margin: 2px 0 0 0; color: #000; font-size: 15px; }
    .btn-primary {
      display: inline-block;
      background: #fc4f37;
      color: #fff;
      text-decoration: none;
      padding: 16px 32px;
      border-radius: 40px;
      font-size: 16px;
      font-weight: 600;
      border: none;
      cursor: pointer;
      margin-top: 24px;
      transition: background 0.15s;
    }
    .btn-primary:hover { background: #e8402c; }
    .unavailable {
      background: #fff3cd;
      border: 1px solid #ffc107;
      border-radius: 16px;
      padding: 12px;
      margin-top: 24px;
      color: #856404;
      font-size: 14px;
    }
  </style>
</head>
<body>
  <div class="card">
    <div class="logo">
      <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 16 20" width="20" height="25">
        <circle cx="8" cy="8" fill="black" r="8"/>
        <path d="M8.00003 16L10.3094 20H5.69063L8.00003 16Z" fill="black"/>
      </svg>
    </div>
    <h1>Verify your identity to join this group</h1>
    <p class="subtitle">You've been invited to a Convos group</p>

    <img src="/icons/<%= namespace %>" alt="<%= displayName %>" class="app-icon" />

    <dl class="info">
      <dt>Group</dt>
      <dd><%= groupTitle %></dd>
      <dt>Verified by</dt>
      <dd><%= displayName %></dd>
      <dt>Verification domain</dt>
      <dd><%= verificationDomain %></dd>
    </dl>

    <% if (healthy) { %>
      <a href="<%= verifyUrl %>" class="btn-primary">Verify your identity</a>
    <% } else { %>
      <div class="unavailable">
        Verification is temporarily unavailable. Please try again later.
      </div>
    <% } %>
  </div>
</body>
</html>
