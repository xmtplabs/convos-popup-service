<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Join Group - Convos</title>
  <style>
    body { font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif; max-width: 480px; margin: 40px auto; padding: 0 20px; color: #333; }
    .card { border: 1px solid #e0e0e0; border-radius: 12px; padding: 24px; text-align: center; }
    h1 { font-size: 1.4em; margin-bottom: 8px; }
    .subtitle { color: #666; margin-bottom: 20px; }
    .info { background: #f7f7f7; border-radius: 8px; padding: 12px; margin: 16px 0; text-align: left; font-size: 0.9em; }
    .info dt { font-weight: 600; margin-top: 8px; }
    .info dd { margin: 2px 0 0 0; color: #555; }
    .verify-btn { display: inline-block; background: #0066ff; color: white; text-decoration: none; padding: 12px 32px; border-radius: 8px; font-size: 1em; margin-top: 16px; }
    .verify-btn:hover { background: #0052cc; }
    .app-icon { width: 64px; height: 64px; border-radius: 12px; object-fit: contain; }
    .unavailable { background: #fff3cd; border: 1px solid #ffc107; border-radius: 8px; padding: 12px; margin-top: 16px; color: #856404; }
  </style>
</head>
<body>
  <div class="card">
    <h1>Verify your identity to join this group</h1>
    <p class="subtitle">You've been invited to a Convos group</p>

    <img src="/icons/<%= namespace %>" alt="<%= displayName %>" class="app-icon" />

    <dl class="info">
      <dt>Group</dt>
      <dd><%= groupTitle %></dd>
      <dt>Verified by</dt>
      <dd><%= displayName %></dd>
      <dt>Verification domain</dt>
      <dd><%= verificationDomain %></dd>
    </dl>

    <% if (healthy) { %>
      <a href="<%= verifyUrl %>" class="verify-btn">Verify your identity</a>
    <% } else { %>
      <div class="unavailable">
        Verification is temporarily unavailable. Please try again later.
      </div>
    <% } %>
  </div>
</body>
</html>
