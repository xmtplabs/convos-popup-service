<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="referrer" content="no-referrer">
  <title>Join Group - Convos</title>
  <style>
    body { font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif; max-width: 480px; margin: 40px auto; padding: 0 20px; color: #333; text-align: center; }
    .card { border: 1px solid #e0e0e0; border-radius: 12px; padding: 24px; }
    h1 { font-size: 1.4em; margin-bottom: 8px; }
    .qr-container { margin: 24px 0; }
    .qr-container svg { max-width: 256px; max-height: 256px; }
    .instructions { color: #666; font-size: 0.95em; }
    .deeplink { display: block; margin-top: 16px; color: #0066cc; font-size: 0.85em; word-break: break-all; }
  </style>
</head>
<body>
  <div class="card">
    <h1>Scan to join group</h1>
    <p class="instructions">Open the Convos app and scan this QR code to join the group.</p>
    <div class="qr-container">
      <%- qrSvg %>
    </div>
    <a href="<%= joinUrl %>" class="deeplink"><%= joinUrl %></a>
  </div>
</body>
</html>
