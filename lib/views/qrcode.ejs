<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="referrer" content="no-referrer">
  <title>Join Group - Convos</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body {
      font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
      max-width: 480px;
      margin: 0 auto;
      padding: 48px 20px;
      color: #000;
      background: #fff;
      -webkit-font-smoothing: antialiased;
      text-align: center;
    }
    p {
      font-size: 15px;
      font-weight: 500;
    }
    .card {
      border: 1px solid #ebebeb;
      border-radius: 24px;
      padding: 40px 32px;
    }
    .logo { margin-bottom: 24px; display: flex; justify-content: center; align-items: center; gap: 8px; }
    h1 { font-size: 32px; font-weight: 700; letter-spacing: -0.5px; }
    .group-title { color: #666; font-size: 15px; margin: 8px 0 0; }
    .app-branding {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      font-size: 14px;
      color: #666;
    }
    img.app-branding {
      width: 24px;
      height: 24px;
      border-radius: 6px;
      object-fit: contain;
    }
    .qr-container {
      box-shadow: 0px 4px 16px #eee, 0px 0px 3px #ddd;
      margin: 24px auto;
      border-radius: 32px;
      padding: 24px;
      display: inline-block;
    }
    .qr-container svg { width: 100%; height: auto; display: block; max-width: 256px; }
    .btn-secondary {
      display: inline-block;
      background: #fff;
      color: #000;
      text-decoration: none;
      padding: 14px 32px;
      border-radius: 40px;
      font-size: 15px;
      font-weight: 500;
      border: 1px solid #ebebeb;
      cursor: pointer;
      transition: border-color 0.15s;
    }
    .btn-secondary:hover { border-color: #777; }
  </style>
</head>
<body>
  <div class="card">
    <div class="logo">
      <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 16 20" width="20" height="25">
        <circle cx="8" cy="8" fill="black" r="8"/>
        <path d="M8.00003 16L10.3094 20H5.69063L8.00003 16Z" fill="black"/>
      </svg>
      <span>Convos &#x00D7;</span>
      <img class="app-branding" src="/icons/<%= namespace %>" alt="<%= displayName %>" />
    </div>
    <h1>You're invited to <%= groupTitle %></h1>
    <br>
    <p>Scan to join</p>
    <div class="qr-container">
      <%- qrSvg %>
    </div>
    <a href="<%= joinUrl %>" class="btn-secondary">Join on the Web</a>
  </div>
</body>
</html>
