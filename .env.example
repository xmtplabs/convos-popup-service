# Server
PORT=3000
NODE_ENV=development
BASE_URL=http://localhost:3000

# Redis (optional — falls back to MemoryStorage if not set)
REDIS_URL=redis://localhost:6379

# Token signing secrets (each must be a strong random string)
ACCESS_TOKEN_SECRET=change-me-access-token-secret
INVITE_TOKEN_SECRET=change-me-invite-token-secret
APPROVAL_TOKEN_SECRET=change-me-approval-token-secret

# Admin
ADMIN_TOKEN=change-me-admin-token

# XMTP agent (optional — falls back to MockAgent if not set)
XMTP_AGENT_KEY=
XMTP_DB_ENCRYPTION_KEY=
XMTP_ENV=dev
XMTP_DB_DIRECTORY=.convos-agent

# Health checker
HEALTH_CHECK_INTERVAL_MS=60000
HEALTH_CHECK_TIMEOUT_MS=5000

# Notifications (optional — logs to stdout if not set)
SLACK_WEBHOOK_URL=
