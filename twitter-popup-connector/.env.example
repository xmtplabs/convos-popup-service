# Server
TX_PORT=4100
TX_BASE_URL=http://localhost:4100

# Popup service
POPUP_SERVICE_URL=http://localhost:3000
TX_NAMESPACE=x-twitter
TX_DISPLAY_NAME=X (Twitter) Connector
TX_CONTACT_EMAIL=admin@example.com
TX_APP_ICON_URL=https://placehold.co/400.png

# Pre-provisioned popup service credentials (optional — auto-registered if empty)
TX_CLIENT_ID=
TX_CLIENT_SECRET=

# Twitter bot app (OAuth 1.0a — for bot actions)
TWITTER_API_KEY=
TWITTER_API_SECRET=
TWITTER_ACCESS_TOKEN=
TWITTER_ACCESS_SECRET=
TWITTER_BOT_USERNAME=ConvosConnect

# Twitter OAuth 2.0 app (PKCE — for user verification)
TWITTER_OAUTH_CLIENT_ID=
TWITTER_OAUTH_CLIENT_SECRET=

# OpenAI
OPENAI_API_KEY=

# Account Activity API (optional — enables real-time webhook instead of polling)
TWITTER_WEBHOOK_ENV=

# Polling (used when webhook is not configured)
TX_POLL_INTERVAL_MS=15000
