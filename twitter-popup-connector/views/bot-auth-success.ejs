<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Bot Authorized</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body {
      font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
      max-width: 480px;
      margin: 0 auto;
      padding: 48px 20px;
      color: #000;
      background: #fff;
      -webkit-font-smoothing: antialiased;
    }
    .card {
      border: 1px solid #ebebeb;
      border-radius: 24px;
      padding: 40px 32px;
    }
    .logo { text-align: center; margin-bottom: 24px; }
    h1 { font-size: 32px; font-weight: 700; letter-spacing: -0.5px; text-align: center; }
    p { font-size: 15px; color: #666; margin-top: 8px; text-align: center; }
    .username { color: #000; font-weight: 600; }
    .note { color: #b2b2b2; font-size: 13px; margin-top: 16px; text-align: center; }
  </style>
</head>
<body>
  <div class="card">
    <div class="logo">
      <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 16 20" width="20" height="25">
        <circle cx="8" cy="8" fill="black" r="8"/>
        <path d="M8.00003 16L10.3094 20H5.69063L8.00003 16Z" fill="black"/>
      </svg>
    </div>
    <h1>Bot Authorized</h1>
    <p>Signed in as <span class="username">@<%= username %></span></p>
    <p class="note">You can close this window.</p>
  </div>
</body>
</html>
