<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Registration - Test X Service</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=IBM+Plex+Mono:wght@400;500&display=swap" rel="stylesheet">
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body {
      font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
      max-width: 480px;
      margin: 0 auto;
      padding: 48px 20px;
      color: #000;
      background: #fff;
      -webkit-font-smoothing: antialiased;
    }
    .card {
      border: 1px solid #ebebeb;
      border-radius: 24px;
      padding: 40px 32px;
    }
    .logo { text-align: center; margin-bottom: 24px; }
    h1 { font-size: 32px; font-weight: 700; letter-spacing: -0.5px; text-align: center; }
    .field { margin: 16px 0; }
    .field dt {
      font-size: 13px;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 0.5px;
      color: #b2b2b2;
    }
    .field dd {
      margin: 6px 0 0 0;
      font-family: 'IBM Plex Mono', monospace;
      font-size: 13px;
      word-break: break-all;
      background: #f5f5f5;
      padding: 8px 12px;
      border-radius: 8px;
    }
    .warning {
      background: #fff3cd;
      border: 1px solid #ffc107;
      padding: 12px 16px;
      border-radius: 16px;
      margin-top: 20px;
      color: #856404;
      font-size: 14px;
    }
  </style>
</head>
<body>
  <div class="card">
    <div class="logo">
      <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 16 20" width="20" height="25">
        <circle cx="8" cy="8" fill="black" r="8"/>
        <path d="M8.00003 16L10.3094 20H5.69063L8.00003 16Z" fill="black"/>
      </svg>
    </div>
    <h1>Namespace Registration</h1>
    <dl class="field">
      <dt>Namespace</dt>
      <dd><%= namespace %></dd>
    </dl>
    <dl class="field">
      <dt>Client ID</dt>
      <dd><%= clientId %></dd>
    </dl>
    <dl class="field">
      <dt>Client Secret</dt>
      <dd><%= clientSecret %></dd>
    </dl>
    <dl class="field">
      <dt>Status</dt>
      <dd><%= status %></dd>
    </dl>
    <div class="warning">
      Save the client secret now. It will not be shown again.
    </div>
  </div>
</body>
</html>
