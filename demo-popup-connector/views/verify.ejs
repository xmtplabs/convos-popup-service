<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Verify Your Identity - Test X Service</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body {
      font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
      max-width: 480px;
      margin: 0 auto;
      padding: 48px 20px;
      color: #000;
      background: #fff;
      -webkit-font-smoothing: antialiased;
    }
    .card {
      border: 1px solid #ebebeb;
      border-radius: 24px;
      padding: 40px 32px;
    }
    .logo { text-align: center; margin-bottom: 24px; }
    h1 { font-size: 32px; font-weight: 700; letter-spacing: -0.5px; text-align: center; }
    p { font-size: 15px; color: #666; margin-top: 8px; text-align: center; }
    label { display: block; margin-top: 20px; font-size: 14px; font-weight: 600; color: #000; }
    input[type="text"] {
      width: 100%;
      padding: 12px 16px;
      border: 1px solid #ebebeb;
      border-radius: 12px;
      font-size: 15px;
      font-family: inherit;
      margin-top: 6px;
      transition: border-color 0.15s;
    }
    input[type="text"]:focus { outline: none; border-color: #000; }
    .btn-primary {
      display: block;
      width: 100%;
      background: #fc4f37;
      color: #fff;
      text-decoration: none;
      padding: 16px 32px;
      border-radius: 40px;
      font-size: 16px;
      font-weight: 600;
      font-family: inherit;
      border: none;
      cursor: pointer;
      margin-top: 24px;
      transition: background 0.15s;
    }
    .btn-primary:hover { background: #e8402c; }
    .note { color: #b2b2b2; font-size: 13px; margin-top: 16px; text-align: center; }
  </style>
</head>
<body>
  <div class="card">
    <div class="logo">
      <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 16 20" width="20" height="25">
        <circle cx="8" cy="8" fill="black" r="8"/>
        <path d="M8.00003 16L10.3094 20H5.69063L8.00003 16Z" fill="black"/>
      </svg>
    </div>
    <h1>Verify Your Identity</h1>
    <p>Enter your name or handle to verify for this invite.</p>
    <form method="POST" action="/verify-complete">
      <input type="hidden" name="invite_id" value="<%= invite_id %>">
      <input type="hidden" name="callback" value="<%= callback %>">
      <input type="hidden" name="namespace" value="<%= namespace %>">
      <label for="name">Your name / handle</label>
      <input type="text" id="name" name="name" required placeholder="e.g. @alice">
      <button type="submit" class="btn-primary">Verify</button>
    </form>
    <p class="note">This is a test verification service. In production, this would use real platform OAuth.</p>
  </div>
</body>
</html>
