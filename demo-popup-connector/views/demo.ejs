<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Demo - Create Group</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body {
      font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
      max-width: 580px;
      margin: 0 auto;
      padding: 48px 20px;
      color: #000;
      background: #fff;
      -webkit-font-smoothing: antialiased;
    }
    .card {
      border: 1px solid #ebebeb;
      border-radius: 24px;
      padding: 40px 32px;
    }
    .logo { text-align: center; margin-bottom: 24px; }
    h1 { font-size: 32px; font-weight: 700; letter-spacing: -0.5px; text-align: center; }
    label { display: block; margin-top: 20px; font-size: 14px; font-weight: 600; color: #000; }
    input[type="text"] {
      width: 100%;
      padding: 12px 16px;
      border: 1px solid #ebebeb;
      border-radius: 12px;
      font-size: 15px;
      font-family: inherit;
      margin-top: 6px;
      transition: border-color 0.15s;
    }
    input[type="text"]:focus { outline: none; border-color: #000; }
    .btn-primary {
      display: block;
      width: 100%;
      background: #fc4f37;
      color: #fff;
      text-decoration: none;
      padding: 16px 32px;
      border-radius: 40px;
      font-size: 16px;
      font-weight: 600;
      font-family: inherit;
      border: none;
      cursor: pointer;
      margin-top: 24px;
      transition: background 0.15s;
    }
    .btn-primary:hover { background: #e8402c; }
    .result {
      margin-top: 24px;
      background: #f5f5f5;
      padding: 20px;
      border-radius: 16px;
    }
    .result h3 { font-size: 16px; font-weight: 600; margin-bottom: 8px; }
    .result p { font-size: 14px; color: #666; margin-top: 4px; }
    .result a { color: #fc4f37; word-break: break-all; }
  </style>
</head>
<body>
  <div class="card">
    <div class="logo">
      <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 16 20" width="20" height="25">
        <circle cx="8" cy="8" fill="black" r="8"/>
        <path d="M8.00003 16L10.3094 20H5.69063L8.00003 16Z" fill="black"/>
      </svg>
    </div>
    <h1>Create Group (Demo)</h1>
    <form method="POST" action="/demo/create-group">
      <label for="title">Group Title</label>
      <input type="text" id="title" name="title" required placeholder="Chat between @alice and @bob">
      <label for="pairingIds">Pairing Identifiers (comma-separated)</label>
      <input type="text" id="pairingIds" name="pairingIds" required placeholder="@alice, @bob">
      <button type="submit" class="btn-primary">Create Group</button>
    </form>

    <% if (typeof result !== 'undefined' && result) { %>
      <div class="result">
        <h3>Group Created: <%= result.groupId %></h3>
        <p><strong>Invite URL:</strong> <a href="<%= result.inviteUrl %>" target="_blank"><%= result.inviteUrl %></a></p>
        <p><strong>Pairing Identifiers:</strong> <%= result.pairingIdentifiers.join(', ') %></p>
      </div>
    <% } %>
  </div>
</body>
</html>
