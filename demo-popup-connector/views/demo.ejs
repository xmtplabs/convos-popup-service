<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Demo - Create Group</title>
  <style>
    body { font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif; max-width: 580px; margin: 40px auto; padding: 0 20px; color: #333; }
    .card { border: 1px solid #e0e0e0; border-radius: 12px; padding: 24px; }
    h1 { font-size: 1.4em; }
    label { display: block; margin-top: 16px; font-weight: 600; }
    input[type="text"] { width: 100%; padding: 10px; border: 1px solid #ccc; border-radius: 6px; font-size: 1em; box-sizing: border-box; margin-top: 4px; }
    button { display: block; width: 100%; background: #0066ff; color: white; border: none; padding: 12px; border-radius: 8px; font-size: 1em; cursor: pointer; margin-top: 20px; }
    .result { margin-top: 20px; background: #f0f8ff; padding: 16px; border-radius: 8px; }
    .result a { word-break: break-all; }
  </style>
</head>
<body>
  <div class="card">
    <h1>Create Group (Demo)</h1>
    <form method="POST" action="/demo/create-group">
      <label for="title">Group Title</label>
      <input type="text" id="title" name="title" required placeholder="Chat between @alice and @bob">
      <label for="pairingIds">Pairing Identifiers (comma-separated)</label>
      <input type="text" id="pairingIds" name="pairingIds" required placeholder="@alice, @bob">
      <button type="submit">Create Group</button>
    </form>

    <% if (typeof result !== 'undefined' && result) { %>
      <div class="result">
        <h3>Group Created: <%= result.groupId %></h3>
        <p><strong>Invite URL:</strong> <a href="<%= result.inviteUrl %>" target="_blank"><%= result.inviteUrl %></a></p>
        <p><strong>Pairing Identifiers:</strong> <%= result.pairingIdentifiers.join(', ') %></p>
      </div>
    <% } %>
  </div>
</body>
</html>
